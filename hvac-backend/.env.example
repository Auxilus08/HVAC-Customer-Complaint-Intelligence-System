# ══════════════════════════════════════════════════════════════════════════════
# HVAC Complaint Intelligence System — Backend Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hvac_complaints
POSTGRES_USER=hvac_user
POSTGRES_PASSWORD=change_me_in_production

# Constructed URLs (used by SQLAlchemy and Alembic)
DATABASE_URL=postgresql+asyncpg://hvac_user:change_me_in_production@localhost:5432/hvac_complaints
DATABASE_SYNC_URL=postgresql+psycopg2://hvac_user:change_me_in_production@localhost:5432/hvac_complaints

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── LLM provider (deepseek | qwen | gemini) ──────────────────────────────────
# Switch the active provider here. All three are accessed via the OpenAI SDK
# against the provider's compatible-mode endpoint.
LLM_PROVIDER=deepseek

# Google Generative AI (Gemini) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qwen / Alibaba DashScope — https://dashscope.console.aliyun.com/
QWEN_API_KEY=sk-your-qwen-key-here
# Text model — Qwen's flagship for chat/reasoning. Used for product matching,
# triage classification, and tip generation.
QWEN_MODEL=qwen-max-latest
# Vision model — used when a customer sends an image (e.g. a photo of the
# HVAC product's nameplate). Reads model numbers, SKUs, and other label text.
QWEN_VISION_MODEL=qwen-vl-max-latest
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
# Minimum 32 characters, random — generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_32_chars_minimum_required_here_please
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Security / Encryption ─────────────────────────────────────────────────────
# 32-byte base64-encoded keys for AES-256-GCM
# Generate each with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
RAW_TEXT_ENCRYPTION_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY
PII_ENCRYPTION_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY
RAW_TEXT_RETENTION_DAYS=90

# ── ML / Embeddings ──────────────────────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_MODEL_VERSION=v1.0
EMBEDDING_DIM=384
EMBEDDING_CACHE_TTL_SECONDS=86400

# ── UMAP / Clustering ─────────────────────────────────────────────────────────
UMAP_RANDOM_STATE=42
UMAP_N_COMPONENTS_CLUSTER=50
UMAP_N_COMPONENTS_VIZ=2
HDBSCAN_MIN_CLUSTER_SIZE=15
CLUSTER_FINGERPRINT_THRESHOLD=0.2

# ── Sentiment Thresholds ─────────────────────────────────────────────────────
# VADER compound score boundaries
SENTIMENT_HIGH_THRESHOLD=-0.5
SENTIMENT_CRITICAL_THRESHOLD=-0.8

# ── Alert Thresholds ─────────────────────────────────────────────────────────
EMERGING_CLUSTER_GROWTH_THRESHOLD=0.5
CRITICAL_SENTIMENT_THRESHOLD=-0.6
MIN_COMPLAINTS_FOR_ALERT=10

# ── Celery Beat Schedule ─────────────────────────────────────────────────────
# Cron syntax: minute hour day_of_month month day_of_week
CLUSTER_JOB_CRON=0 2 * * *

# ── Telegram Support Bot ─────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then paste the HTTP API token below.
# Long-polling mode — the worker calls Telegram's getUpdates on a loop, so no
# public URL / webhook is required. Toggle TELEGRAM_ENABLED=true to start polling.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=false
TELEGRAM_POLL_INTERVAL_SECONDS=2
TELEGRAM_LONG_POLL_TIMEOUT_SECONDS=25
TELEGRAM_API_BASE_URL=https://api.telegram.org
# Minimum LLM confidence (0-1) for an AI-resolvable verdict before escalation.
TELEGRAM_AI_CONFIDENCE_THRESHOLD=0.65
