{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(tree:*)",
      "Bash(pwd)",
      "Bash(which:*)",

      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote -v)",
      "Bash(git ls-files:*)",
      "Bash(git blame:*)",
      "Bash(git stash list)",

      "Bash(make help)",
      "Bash(make lint)",
      "Bash(make test)",
      "Bash(make test-unit)",
      "Bash(make test-integ)",
      "Bash(make test-compliance)",
      "Bash(make format)",
      "Bash(make check-pii)",
      "Bash(make demo-check)",

      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(mypy:*)",
      "Bash(pytest:*)",

      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run test:*)",
      "Bash(npx eslint:*)",

      "Bash(docker compose ps)",
      "Bash(docker compose logs:*)",
      "Bash(docker ps)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(sudo rm:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(make down)",
      "Bash(docker compose down:*)",
      "Bash(docker system prune:*)"
    ]
  }
}
